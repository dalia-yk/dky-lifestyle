// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  phone     String?
  createdAt DateTime  @default(now())
  bookings  Booking[]
}

enum ServiceCategory {
  COLLECTION
  HAIR_CARE
  PREPARATION
}

model Service {
  id                      String          @id @default(cuid())
  slug                    String          @unique
  name                    String
  tagline                 String
  description             String
  duration                String
  priceFrom               Int
  priceWithoutExtensions  Int?
  extensionFee            Int             @default(0)
  extensionsMode          ExtensionsMode  @default(OPTIONAL)
  requiresLength          Boolean         @default(true)
  requiresSize            Boolean         @default(true)
  category                ServiceCategory @default(COLLECTION)
  collection              String
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  bookings                Booking[]
  compatiblePackages      Package[]       @relation("PackageCompatibleServices")
  availableFor Audience[]
}

model AddOn {
  id       String    @id @default(cuid())
  name     String    @unique
  price    Int
  bookings Booking[] @relation("BookingAddOns")
  packages Package[] @relation("PackageAddOns")
}

model Package {
  id                  String    @id @default(cuid())
  name                String
  tagline             String
  featured            Boolean   @default(false)
  price               Int       @default(0)
  includesPremiumHair Boolean   @default(false)
  includedAddOns      AddOn[]   @relation("PackageAddOns")
  compatibleServices  Service[] @relation("PackageCompatibleServices")
  bookings            Booking[]
}

model Booking {
  id                String        @id @default(cuid())
  bookingSeq        Int           @default(autoincrement())
  client            Client        @relation(fields: [clientId], references: [id])
  clientId          String
  service           Service       @relation(fields: [serviceId], references: [id])
  serviceId         String
  package           Package?      @relation(fields: [packageId], references: [id])
  packageId         String?
  date              DateTime
  time              String
  status            BookingStatus @default(PENDING)
  category           String?
  size              String?
  length            String?
  hairOption        String?
  hairColor         String?
  addOns            AddOn[]       @relation("BookingAddOns")
  locationType      LocationType  @default(SALON)
  address           String?
  inspirationPhotos String[]
  estimatedDuration String?
  totalPrice        Int
  depositAmount     Int
  remainingBalance  Int
  paymentStatus     PaymentStatus @default(PENDING)
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum LocationType {
  SALON
  HOME
}

enum PaymentStatus {
  PENDING
  DEPOSIT_REQUESTED
  PAID
}

enum ExtensionsMode {
  REQUIRED
  OPTIONAL
  NOT_ALLOWED
}

enum Audience {
  FEMMES
  HOMMES
  ENFANTS
}
